{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "discussion-popup",
  "description": "Allow Disqus login popups to request Steam's keyboard and close themselves after authentication.",
  "windows": ["discussion-popup-*"],
  "remote": {
    "urls": ["https://disqus.com/**", "https://*.disqus.com/**"]
  },
  "platforms": ["linux"],
  "permissions": ["allow-steam-show-osk"]
}
