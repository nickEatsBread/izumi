{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "izumi",
  "version": "0.1.0",
  "identifier": "com.nicho.izumi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "izumi",
        "width": 1280,
        "height": 800,
        "transparent": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 26
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDNzBBRUE0MjVFMDk3OUMKUldTY2wrQWxwSzV3VEgxdHEvUlhyVzJLMXMzZ1F0LzlHc05OQUIrRnNnMHdXbnB1WlNBNlI3RUgK",
      "endpoints": [
        "https://github.com/nickEatsBread/izumi/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
