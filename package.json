{
  "name": "izumi",
  "version": "0.1.8",
  "description": "izumi — a native desktop anime client",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "android:studio": "tauri android dev --open",
    "android:studio:full": "tauri android dev --open --features android-mpv --config src-tauri/tauri.android-mpv.conf.json",
    "gen:android-icons": "node scripts/gen-android-icons.mjs"
  },
  "dependencies": {
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource/geist-mono": "^5.2.8",
    "@nicholasyoannou/hayami-sdk": "github:nicholasyoannou/hayami-sdk",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-haptics": "^2",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@urql/exchange-auth": "^3.0.0",
    "@urql/exchange-graphcache": "^9.0.1",
    "@urql/svelte": "^5.0.0",
    "bottleneck": "^2.19.5",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "idb-keyval": "^6.2.6",
    "lucide-svelte": "^1.0.1",
    "sucrase": "^3.35.1",
    "svelte-persisted-store": "^0.12.0",
    "urql": "^5.0.3",
    "wonka": "^6.3.6"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.20.1",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
