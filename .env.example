# Copy to .env. These are PUBLIC OAuth client IDs (not secrets) — implicit/PKCE
# grants need no client secret. Register your apps with the redirect URI below.
PUBLIC_ANILIST_CLIENT_ID=your-anilist-client-id
PUBLIC_MAL_CLIENT_ID=your-mal-client-id
PUBLIC_OAUTH_REDIRECT_URI=https://animeclient.quack.co.uk/callback
